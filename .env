# Bippy! environment template
#
# Real values live in .env.local (gitignored). This file is committed
# so it documents which keys exist, never the secrets themselves.
#
# Vercel Blob read-write token. Used ONLY by scripts/upload-flashcard.js
# from a dev machine — never bundled into the app. The mobile app sees
# only the public URLs that the script returns.
BLOB_READ_WRITE_TOKEN=
